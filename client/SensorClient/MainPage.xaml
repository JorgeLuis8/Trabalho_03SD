<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SensorClient.MainPage"
             Title="Simulador de Sensor">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">
            
            <Label Text="Monitor de Temperatura" 
                   FontSize="22" 
                   HorizontalOptions="Center" 
                   FontAttributes="Bold" />

            <Border Stroke="LightGray"
                    StrokeThickness="1"
                    Padding="15"
                    HorizontalOptions="Center"
                    StrokeShape="RoundRectangle 10">
                <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                    <Label x:Name="lblTemp" 
                           Text="-- °C" 
                           FontSize="50" 
                           HorizontalOptions="Center" 
                           TextColor="#2196F3" />
                    
                    <Label x:Name="lblStatus" 
                           Text="Aguardando..." 
                           FontSize="18" 
                           HorizontalOptions="Center" 
                           TextColor="DimGray" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Gerar e Enviar Leitura" 
                    Clicked="OnEnviarClicked" 
                    HeightRequest="50"
                    BackgroundColor="#2196F3"
                    TextColor="White" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label Text="Histórico Local:" FontAttributes="Bold" />
            
            <CollectionView x:Name="listHistorico" HeightRequest="250">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding .}" Padding="2" FontSize="12" TextColor="#444" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>